<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Produk"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Isi detail produk kamu"
            android:textSize="14sp"
            android:textColor="#7A7A7A" />

        <!-- Card Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="6dp"
            android:layout_marginBottom="20dp">

            <!-- Nama Produk -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Produk"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#7B61FF"
                android:hint="Contoh: iPhone 15 Pro"
                android:padding="14dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0" />

            <!-- Harga -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#7B61FF"
                android:hint="Masukkan harga"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0" />

            <!-- Rating -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etRating"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#7B61FF"
                android:hint="0 - 5 ⭐"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0" />

            <!-- Deskripsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:backgroundTint="#7B61FF"
                android:gravity="top"
                android:hint="Tulis deskripsi produk..."
                android:padding="14dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0" />

        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:backgroundTint="#7B61FF"
            android:text="Simpan Produk"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>